{
  "expo": {
    "name": "FinTrack Pro",
    "slug": "fintrack-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "fintrack",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8b5cf6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sandeshkadel.fintrackpro",
      "buildNumber": "1.0.0",
      "icon": "./src/assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "FinTrack Pro uses the camera to scan receipts and capture profile photos.",
        "NSPhotoLibraryUsageDescription": "FinTrack Pro needs access to your photo library to attach receipt images.",
        "NSPhotoLibraryAddUsageDescription": "FinTrack Pro saves exported reports and profile pictures to your photo library.",
        "NSFaceIDUsageDescription": "FinTrack Pro uses Face ID to keep your financial data secure.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sandeshkadel.fintrackpro",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#8b5cf6"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "USE_FINGERPRINT",
        "USE_BIOMETRIC",
        "USE_FULL_SCREEN_INTENT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "FinTrack Pro needs access to your photo library to attach receipt images.",
          "cameraPermission": "FinTrack Pro uses the camera to scan receipts and capture profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#8b5cf6"
        }
      ],
      "expo-local-authentication",
      [
        "expo-sqlite",
        {
          "enablePromiseBasedAPI": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
